# Public site URL (used for OAuth redirect_uri). For local dev with Vite, use the Vite origin
# (not 127.0.0.1) so cookies and redirect_uri match what you open in the browser:
SITE_ORIGIN=http://localhost:5173

# Random secret for signed cookies (generate e.g. openssl rand -hex 32).
# Prefer SESSION_SECRET; CLA_SESSION_SECRET is still accepted for older configs.
SESSION_SECRET=
CLA_SESSION_SECRET=

# GitHub OAuth app (Settings → Developer settings → OAuth Apps)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Optional: CLA document version string stored on accept
# CLA_SDK_VERSION=1

# Repo whose CLA.md is shown on /cla (owner/repo, branch main). Separate from CLA_BOT_REPOS.
# CLA_SOURCE_REPO=vex-protocol/spire-js

# --- Require an open PR before POST /api/gh/accept (GitHub Search API) ---
# Set one or both. If set, the signed-in user must have ≥1 open PR matching the query.
# CLA_PR_CHECK_ORG=vex-protocol
# CLA_PR_CHECK_REPOS=vex-protocol/spire-js,vex-protocol/libvex-js,vex-protocol/crypto-js
# Strongly recommended (rate limits + reliability):
# GITHUB_CLA_PR_CHECK_TOKEN=

# CLA queue on disk (default ./data/cla-pending.json under process cwd)
# CLA_QUEUE_PATH=

# --- Who can use Admin → CLA queue (and /api/gh/admin/*) ---
#
# If set, ONLY these GitHub logins (comma-separated). Ignores org/repo checks below.
# CLA_ADMIN_LOGINS=
#
# Vex org members: set org slug. Recommended: a PAT with permission to list org members
# (`GET /orgs/{org}/members`, paginated + cached server-side). Compares login to the full list.
# CLA_ADMIN_ORG=vex-protocol
# GITHUB_ORG_MEMBERSHIP_TOKEN=
#
# Without GITHUB_ORG_MEMBERSHIP_TOKEN: after sign-in, membership is checked with the user’s
# OAuth token via `GET /user/memberships/orgs/{org}` (needs `read:org` on the OAuth app).
#
# Optional extra: also allow users with write+ on a specific repo (classic PAT + owner/repo).
# GITHUB_CLA_ADMIN_TOKEN=
# CLA_ADMIN_REPO=vex-protocol/spire-js

# Auto-update .clabot on GitHub when an admin approves (contents:write on each repo).
# Each repo has its own .clabot file; this list is what the admin queue updates.
# GITHUB_CLA_BOT_TOKEN=
# CLA_BOT_REPOS=vex-protocol/spire-js,vex-protocol/libvex-js,vex-protocol/crypto-js

# Local API server port (default 8787). Vite’s dev proxy uses the same value — change both if 8787 is busy.
# CLA_API_PORT=8788
