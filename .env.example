# =============================================================================
# WHERE TO PUT THESE
# =============================================================================
# File path:   vex.wtf/.env   (same directory as vex.wtf/package.json)
# After edits: restart the API process (`npm run dev:api` locally; redeploy / restart in prod).
# =============================================================================
# vex.wtf — environment setup
# Copy from this example:  cp .env.example .env   then fill in secrets.
# =============================================================================
#
# LOCAL DEV (typical)
# -------------------
# 1. Terminal A: `npm run dev`        → Vite on http://localhost:5173
# 2. Terminal B: `npm run dev:api`    → API on CLA_API_PORT (default 8787), proxies from /api
# 3. Open the SAME origin you put in SITE_ORIGIN (e.g. http://localhost:5173 — not 127.0.0.1)
#
# GITHUB OAUTH APP (required for sign-in / CLA)
# ----------------------------------------------
# Create: https://github.com/settings/developers → OAuth Apps → New
#   • Application name: anything
#   • Homepage URL: http://localhost:5173 (or your prod URL)
#   • Authorization callback URL: MUST be exactly:
#         {SITE_ORIGIN}/api/gh/callback
#     Example local:  http://localhost:5173/api/gh/callback
#     Example prod:   https://vex.wtf/api/gh/callback
#   • Scopes are requested by the app: read:user, read:org
#
# =============================================================================
# REQUIRED — GitHub OAuth + signing cookies
# =============================================================================

SITE_ORIGIN=http://localhost:5173

# openssl rand -hex 32
SESSION_SECRET=

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# =============================================================================
# OPTIONAL — CLA / queue (defaults work for many cases)
# =============================================================================

# Version string stored when someone accepts the CLA (default: 1)
# CLA_SDK_VERSION=1

# Which repo’s CLA.md is shown on /cla (owner/repo, branch main). Default: vex-protocol/spire-js
# CLA_SOURCE_REPO=vex-protocol/spire-js

# Where the JSON queue lives (default: ./data/cla-pending.json under the API process cwd)
# CLA_QUEUE_PATH=

# Append-only CLA audit log (JSON lines). Default: ./data/cla-audit.jsonl
# CLA_AUDIT_PATH=

# =============================================================================
# OPTIONAL — Who may open Admin → CLA queue
# =============================================================================
# Pick ONE primary approach (or combine allowlist with org/repo below).
#
# (A) Explicit allowlist — simplest; use this if org membership is private / listing members is empty:
#     CLA_ADMIN_LOGINS=yuki111888,dream9x
#
# (B) Org members — org defaults to vex-protocol if you omit CLA_ADMIN_ORG.
#     Optional override:
#     CLA_ADMIN_ORG=vex-protocol
#     Use a PAT that can list org members (classic: read:org; or fine-grained with Members read):
#     GITHUB_ORG_MEMBERSHIP_TOKEN=ghp_...
#     Without GITHUB_ORG_MEMBERSHIP_TOKEN, the server falls back to the user’s OAuth token and
#     GET /user/memberships/orgs/{org} (needs read:org on the OAuth app — already requested).
#
# (C) Extra: anyone with write+ on a repo (classic PAT):
#     GITHUB_CLA_ADMIN_TOKEN=ghp_...
#     CLA_ADMIN_REPO=vex-protocol/spire-js
#
# CLA_ADMIN_LOGINS=
# CLA_ADMIN_ORG=vex-protocol
# GITHUB_ORG_MEMBERSHIP_TOKEN=
# GITHUB_CLA_ADMIN_TOKEN=
# CLA_ADMIN_REPO=vex-protocol/spire-js

# =============================================================================
# OPTIONAL — Auto-update .clabot when an admin approves in the dashboard
# =============================================================================
# PAT needs contents:write on each repo. Comma-separated owner/repo list.
# GITHUB_CLA_BOT_TOKEN=
# CLA_BOT_REPOS=vex-protocol/spire-js,vex-protocol/libvex-js,vex-protocol/crypto-js,vex-protocol/clabot-global

# =============================================================================
# OPTIONAL — Block CLA accept until the user has an open PR (GitHub Search API)
# =============================================================================
# set org and/or repos; if unset, PR check is skipped
# CLA_PR_CHECK_ORG=vex-protocol
# CLA_PR_CHECK_REPOS=vex-protocol/spire-js,vex-protocol/libvex-js,vex-protocol/crypto-js
# Strongly recommended (rate limits + reliability):
# GITHUB_CLA_PR_CHECK_TOKEN=

# =============================================================================
# OPTIONAL — local API port (must match Vite proxy; same var in .env)
# =============================================================================
# CLA_API_PORT=8787

# =============================================================================
# PRODUCTION / other
# =============================================================================
# If SITE_ORIGIN is unset, PUBLIC_SITE_URL can be used (see api/lib/siteSession.ts).
# PUBLIC_SITE_URL=https://vex.wtf
# Force Secure cookies on HTTPS behind a proxy:
# FORCE_SECURE_COOKIES=1
